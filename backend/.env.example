# Backend Environment Variables
# Copie este arquivo para .env e configure os valores

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gestao_academica

# JWT
JWT_SECRET=sua_chave_secreta_aqui_mude_em_producao
JWT_EXPIRES_IN=24h

# Server
PORT=3000
NODE_ENV=development

# Frontend (para desenvolvimento)
REACT_APP_API_URL=http://localhost:3000/api

